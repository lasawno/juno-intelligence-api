# Juno Intelligence API — Environment Variables
  # Copy this file to .env and fill in your keys.
  # At least one LLM provider key is required. Groq is recommended (free, fast).

  # ── Server ────────────────────────────────────────────────────────────────────
  PORT=3000

  # ── Optional API key to protect your endpoint ────────────────────────────────
  # If set, all requests must include: Authorization: Bearer <API_KEY>
  JUNO_API_KEY=

  # ── LLM Providers (priority order: Groq → Anthropic → OpenRouter) ────────────

  # Groq — free tier, ultra-low latency (recommended)
  # https://console.groq.com
  GROQ_API_KEY=

  # Anthropic — Claude Haiku fallback
  # https://console.anthropic.com
  ANTHROPIC_API_KEY=

  # OpenRouter — access many models with one key
  # https://openrouter.ai
  OPENROUTER_API_KEY=
  